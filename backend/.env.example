# Database
# ── Development (default) ──────────────────────────────────────────────────────
DATABASE_URL=sqlite:///./dev.db
#
# ── Production (PostgreSQL) ────────────────────────────────────────────────────
# 1. Install the driver:  pip install -e ".[postgres]"
# 2. Set this variable:
# DATABASE_URL=postgresql+psycopg2://USER:PASSWORD@HOST:5432/DBNAME
#
# No code changes needed — SQLAlchemy uses the URL to pick the right driver.
# Run migrations the same way: alembic upgrade head

# Security — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-generate-a-real-secret-key

# JWT settings
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS — comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:5173,http://localhost:5174

# Logging
# Options: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
# Set to "true" to output JSON logs instead of human-readable console logs
JSON_LOGS=false

# Email notifications
# Set NOTIFICATIONS_ENABLED=true and fill in SMTP details to send an email
# to SMTP_NOTIFICATION_TO each time a new application is submitted.
NOTIFICATIONS_ENABLED=false
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
# Optional: display name shown in the From header (e.g. "Acme Careers")
SMTP_FROM_NAME=
# Admin address that receives new-application alerts
SMTP_NOTIFICATION_TO=
